NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# DEV-ONLY: when "true", any authenticated user passes the `requireAdmin`
# middleware. Pair with frontend REACT_APP_ADMIN_BYPASS=true. Set to "false"
# in production once `profiles.role = 'admin'` is configured for real users.
ADMIN_ROLE_BYPASS=false

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Selects the card-payment provider used by /api/orders for paymentMethod=card.
# Allowed values: stripe | payhere | mock (when neither is configured)
PAYMENT_PROVIDER=stripe

# Stripe (international card payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: comma-separated ISO codes Stripe charges in whole units (no ×100). Example: jpy,krw
STRIPE_ZERO_DECIMAL_CURRENCIES=

# PayHere (Sri Lankan gateway). Sandbox=true while testing, switch to false for live.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
PAYHERE_RETURN_URL=
PAYHERE_CANCEL_URL=
PAYHERE_NOTIFY_URL=

# Required to enable POST /api/payments/webhook (non-Stripe / dev). Leave blank
# in production unless you have a non-Stripe provider that posts here. Caller
# must send the same value in the X-Internal-Webhook-Secret header.
INTERNAL_WEBHOOK_SECRET=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_SENDER_ID=TWOWAY
